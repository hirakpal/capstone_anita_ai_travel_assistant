    "motion": "^11.11.17",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1"
  },
  "devDependencies": {
    "vite": "^5.4.1",
    "@vitejs/plugin-react": "^4.3.1",
    "tsx": "^4.19.0",
    "esbuild": "^0.23.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/express": "^4.17.21",
    "typescript": "^5.5.4",
    "tailwindcss": "^4.0.0-alpha.30",
    "@tailwindcss/vite": "^4.0.0-alpha.30"
  }
